# Copy to .env and fill in. All three are optional — the site builds and
# runs fine with any/all of them unset (each integration no-ops).

# PostHog product analytics (cookieless mode — see BaseLayout.astro).
# Get this from your PostHog project settings. Before it will actually
# collect anything, enable "Cookieless server hash mode" under
# Project Settings > Web analytics in that PostHog project.
PUBLIC_POSTHOG_KEY=
PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Sentry error tracking. DSNs are not secret — safe to expose client-side.
# Read at astro.config.mjs build time, so this must be set BEFORE `npm run
# build`/`npm run dev` (not just added to a running dev server's env).
PUBLIC_SENTRY_DSN=

# Vercel Web Analytics needs no env var — it's enabled per-project in the
# Vercel dashboard (Project > Analytics tab) after deploying there.
