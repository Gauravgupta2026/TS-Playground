---
import { getCollection, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

const [entry] = await getCollection("capstone");
const { Content } = await render(entry);
---

<BaseLayout title="Capstone" active="capstone">
  <div class="container" style="padding:56px 28px 20px;">
    <div class="kicker" style="margin-bottom:22px;">Capstone</div>
    <h1 class="heading" style="font-size:44px;margin-top:0;">Research Crew</h1>
    <p class="prose">
      A RAG-powered multi-agent research CLI, portfolio-grade. Gated by Phase 9's readiness drills —
      everything you built in Phases 1–9 gets used here, unassisted.
    </p>
  </div>
  <div class="container" style="padding:0 28px 70px;">
    <article class="lesson-content">
      <Content />
    </article>
  </div>
</BaseLayout>

<style>
  .lesson-content :global(h2) {
    font-family: "Newsreader", serif;
    font-weight: 500;
    font-size: 26px;
    margin: 36px 0 14px;
    color: var(--ink);
  }
  .lesson-content :global(p) {
    font-size: 16px;
    line-height: 1.75;
    color: var(--ink-soft);
    margin: 0 0 16px;
  }
  .lesson-content :global(ul),
  .lesson-content :global(ol) {
    color: var(--ink-soft);
    line-height: 1.7;
    font-size: 15.5px;
    padding-left: 22px;
    margin: 0 0 16px;
  }
  .lesson-content :global(li) { margin-bottom: 6px; }
  .lesson-content :global(code) {
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.9em;
    background: var(--surface-2);
    border: 1px solid var(--border);
    padding: 1px 6px;
    border-radius: 5px;
    color: var(--accent-ink);
  }
  .lesson-content :global(pre) {
    background: var(--code-bg);
    border-radius: 14px;
    padding: 18px;
    overflow: auto;
    margin: 0 0 20px;
    color: #dbe6df;
  }
  .lesson-content :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: inherit;
  }
  .lesson-content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 20px;
    font-size: 14.5px;
  }
  .lesson-content :global(th),
  .lesson-content :global(td) {
    border: 1px solid var(--border);
    padding: 8px 12px;
    text-align: left;
  }
</style>
