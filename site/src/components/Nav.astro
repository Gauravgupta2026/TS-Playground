---
import ThemeToggle from "../islands/ThemeToggle";
import SearchPalette from "../islands/SearchPalette";

interface Props {
  active?: "home" | "phases" | "capstone" | "about";
}
const { active } = Astro.props;

const links = [
  { href: "/", label: "Home", key: "home" },
  { href: "/phases/", label: "Phases", key: "phases" },
  { href: "/capstone/", label: "Capstone", key: "capstone" },
  { href: "/about/", label: "About", key: "about" },
] as const;
---

<div class="nav-bar">
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="brand__mark">TS</span>
      <span class="brand__name">TypeScript Playground</span>
    </a>
    <SearchPalette client:idle />
    <nav class="nav-links">
      {links.map((l) => (
        <a href={l.href} class:list={["nav-link", { "nav-link--active": active === l.key }]}>{l.label}</a>
      ))}
    </nav>
    <a href="https://github.com" class="btn btn--dark" style="text-decoration:none;">View on GitHub ↗</a>
    <ThemeToggle client:load />
  </div>
</div>
